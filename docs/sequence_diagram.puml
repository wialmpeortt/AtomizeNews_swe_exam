@startuml SequenceDiagram_LocalVectorEngine

skinparam backgroundColor white
skinparam sequenceArrowThickness 2
skinparam sequenceParticipant {
    BackgroundColor #EEF2FF
    BorderColor #3B4A9C
}
skinparam sequenceActorBackgroundColor #EEF2FF
skinparam sequenceActorBorderColor #3B4A9C
skinparam sequenceLifeLineBorderColor #3B4A9C
skinparam sequenceMessageAlign center
skinparam noteBorderColor #3B4A9C
skinparam noteBackgroundColor #FFF9E6

title LocalVectorEngine — UML Sequence Diagram\nRAG pipeline: Indexing (once) + Query (per question)

actor User
participant "Program\n(Demo host)" as P
participant "IChunkingService" as CHK
participant "IEmbeddingService" as EMB
participant "IVectorStore\n(BLite HNSW)" as DB

' ═════════════════════════════════════════════════════════
' PHASE 1 — INDEXING (run once per document)
' ═════════════════════════════════════════════════════════
== Phase 1 — Indexing ==

User -> P : IndexDocument(path)
activate P

P -> P : text = File.ReadAllText(path)

P -> CHK : Chunk(documentId, text, source)
activate CHK
CHK --> P : IEnumerable<DocumentChunk>
deactivate CHK

loop for each chunk
    P -> EMB : EmbedAsync(chunk.Text, ct)
    activate EMB
    EMB --> P : float[] embedding (384 dims)
    deactivate EMB

    P -> DB : StoreChunkAsync(chunk, embedding, ct)
    activate DB
    DB --> P : (stored + HNSW updated)
    deactivate DB
end

P --> User : N chunks indexed
deactivate P

note over User, DB #F8F9FF
    Indexing is done **once per document**.
    The HNSW index is then persistent on disk.
end note

' ═════════════════════════════════════════════════════════
' PHASE 2 — QUERY (run for every user question)
' ═════════════════════════════════════════════════════════
== Phase 2 — Query ==

User -> P : Query("...natural-language question...")
activate P

P -> EMB : EmbedAsync(question, ct)
activate EMB
EMB --> P : float[] queryVector (384 dims)
deactivate EMB

P -> DB : SearchAsync(queryVector, topK=5, ct)
activate DB
note right of DB
    HNSW approximate nearest-neighbor search
    over all stored embeddings — O(log N).
end note
DB --> P : IReadOnlyList<SearchResult>\n(chunk + similarity score)
deactivate DB

P --> User : Top-K passages + citations
deactivate P

note over User, DB #F8F9FF
    The retrieved passages are the **context**
    an LLM would use to produce a grounded answer
    (the LLM step is outside this engine's scope).
end note

@enduml
