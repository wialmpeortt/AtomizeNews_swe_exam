@startuml ClassDiagram_LocalVectorEngine

skinparam classAttributeIconSize 0
skinparam classFontStyle Bold
skinparam backgroundColor white
skinparam class {
    BackgroundColor #EEF2FF
    BorderColor #3B4A9C
    ArrowColor #3B4A9C
}
skinparam package {
    BackgroundColor #F8F9FF
    BorderColor #3B4A9C
}

title LocalVectorEngine — UML Class Diagram\nCore library + Demo host

' ─── Core library ────────────────────────────────────────
package "LocalVectorEngine.Core" as Core {

    ' ─── Models ──────────────────────────────────────────
    class "DocumentChunk\n<<record>>" as DocumentChunk {
        + DocumentId : string
        + ChunkIndex : int
        + Text : string
        + Source : string
    }

    class "SearchResult\n<<record>>" as SearchResult {
        + Chunk : DocumentChunk
        + Score : float
    }

    ' ─── Interfaces ──────────────────────────────────────
    interface IChunkingService {
        + Chunk(documentId: string, text: string, source: string) : IEnumerable<DocumentChunk>
    }

    interface IEmbeddingService {
        + EmbedAsync(text: string, ct: CancellationToken) : Task<float[]>
    }

    interface IVectorStore {
        + StoreChunkAsync(chunk: DocumentChunk, embedding: float[], ct: CancellationToken) : Task
        + SearchAsync(queryEmbedding: float[], topK: int, ct: CancellationToken) : Task<IReadOnlyList<SearchResult>>
    }
}

' ─── Planned implementations ─────────────────────────────
package "LocalVectorEngine.Core (implementations)" as Impl {

    class "SlidingWindowChunkingService\n<<planned — Issue #21>>" as ChunkImpl #FFF9E6 {
        - chunkSize : int
        - overlap : int
        + Chunk(..) : IEnumerable<DocumentChunk>
    }

    class "OnnxEmbeddingService\n<<planned — Issue #10>>" as OnnxImpl #FFF9E6 {
        - modelPath : string
        - session : InferenceSession
        + EmbedAsync(text, ct) : Task<float[]>
    }

    class "BLiteVectorStore\n<<planned — Issue #11>>" as BLiteImpl #FFF9E6 {
        - dbPath : string
        - collection : Collection
        + StoreChunkAsync(..) : Task
        + SearchAsync(..) : Task<IReadOnlyList<SearchResult>>
    }
}

' ─── Demo host ──────────────────────────────────────────
package "LocalVectorEngine.Demo" as Demo {
    class Program {
        + Main(args: string[]) : Task
    }
}

' ─── Relationships ──────────────────────────────────────
SearchResult --> DocumentChunk : wraps >

ChunkImpl ..|> IChunkingService
OnnxImpl  ..|> IEmbeddingService
BLiteImpl ..|> IVectorStore

IChunkingService  ..> DocumentChunk : produces >
IEmbeddingService ..> "float[]"      : produces >
IVectorStore      ..> DocumentChunk  : persists >
IVectorStore      ..> SearchResult   : returns >

Program --> IChunkingService  : uses
Program --> IEmbeddingService : uses
Program --> IVectorStore      : uses

@enduml
